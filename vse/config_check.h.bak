/*
 * config_check.h — Hypervisor configuration integrity verification
 *
 * Runs once at boot, before any VM is created.
 * Hashes the active hypervisor configuration and compares against
 * an HMAC-signed golden value embedded in EL2 read-only memory.
 *
 * If verification fails → hyp_panic() — the hypervisor does not boot.
 *
 * First-boot / golden derivation:
 *   Set CONFIG_CHECK_LEARN_MODE 1, boot once, read the logged
 *   golden HMAC from UART, paste it into config_check.c as
 *   _golden_hmac[], then set CONFIG_CHECK_LEARN_MODE back to 0.
 *   Rebuild and flash — subsequent boots enforce the golden value.
 */

#ifndef VSE_CONFIG_CHECK_H
#define VSE_CONFIG_CHECK_H

#include "../include/types.h"
#include "../include/error.h"
#include "hmac.h"

/*
 * Set to 1 during initial bring-up to derive and print the golden HMAC.
 * MUST be 0 in production — learn mode disables enforcement.
 */
#ifndef CONFIG_CHECK_LEARN_MODE
#define CONFIG_CHECK_LEARN_MODE  1
#endif

/*
 * config_blob_t — all hypervisor parameters that must not change
 * between a trusted build and runtime.
 *
 * Any field added here becomes part of the integrity guarantee.
 * Changing a field without re-deriving the golden HMAC will cause
 * a panic at boot — that is the intended behaviour.
 */
typedef struct __packed {
    u32 max_vms;
    u32 max_vcpu_per_vm;
    u32 max_mem_regions;
    u32 max_dev_per_vm;
    u32 max_irq_routes;
    u32 sched_major_frame_us;
    u64 uart_base;
    u64 gicd_base;
    u64 gicr_base;
    u64 linux_vm_pa;
    u64 rtos_vm_pa;
    u64 android_vm_pa;
    u64 shmem_pool_pa;
    u64 shmem_pool_sz;
    u32 log_level;
    u32 _pad;                  /* alignment padding — always zero */
} config_blob_t;

/*
 * config_check_init — call from hyp_main() before vm_subsys_init().
 *
 * Returns E_OK if the configuration matches the golden HMAC.
 * In learn mode: always returns E_OK (logs the derived value instead).
 * In enforce mode: calls hyp_panic() on mismatch — never returns E_INVAL.
 */
err_t config_check_init(void);

/*
 * config_check_get_blob — fills out a config_blob_t from current constants.
 * Exposed for use by the VSE update path to re-verify after a config change.
 */
void config_check_get_blob(config_blob_t *blob);

#endif /* VSE_CONFIG_CHECK_H */
